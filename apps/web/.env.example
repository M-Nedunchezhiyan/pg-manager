# Copy to apps/web/.env.local and fill. Never commit .env.local.
# All these also need to be set in Vercel → Project Settings → Environment Variables.

# ─── Supabase ────────────────────────────────────────────────────────────────
# From Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-public-key...
# service_role bypasses RLS — server-only, NEVER ship to browser. Do not prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key...

# ─── Database (Supabase Postgres) ────────────────────────────────────────────
# From Supabase dashboard → Project Settings → Database → Connection string
# DATABASE_URL uses the pgBouncer pooler (port 6543) — required for Vercel's serverless.
# DIRECT_URL uses the direct connection (port 5432) — required for Prisma migrations.
# Replace [YOUR-PASSWORD] with the DB password you saved when creating the project.
DATABASE_URL=postgresql://postgres.<ref>:[YOUR-PASSWORD]@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres.<ref>:[YOUR-PASSWORD]@aws-0-<region>.pooler.supabase.com:5432/postgres

# ─── Encryption for PII at rest (AES-256-GCM) ────────────────────────────────
# Generate ONCE: openssl rand -hex 32     (must be exactly 64 hex chars)
# This MUST be the same value across all environments — losing it = losing all decrypted PII.
PII_ENCRYPTION_KEY=change_me_64_hex_chars_exactly_for_aes_256_gcm

# ─── Cron secret (protects scheduled endpoints) ──────────────────────────────
# Generate: openssl rand -base64 32
# Vercel sends this as Authorization: Bearer <value> when invoking /api/cron/*
CRON_SECRET=change_me_random_cron_secret

# ─── App URL (used for OAuth redirects + email links) ────────────────────────
# Locally: http://localhost:3000   On Vercel: https://<your>.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Optional: log level ─────────────────────────────────────────────────────
LOG_LEVEL=info
