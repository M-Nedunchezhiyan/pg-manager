{
  "name": "pg-manager",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=22.11.0",
    "pnpm": ">=9.12.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:generate": "pnpm --filter @pg/db prisma generate",
    "db:migrate": "pnpm --filter @pg/db prisma migrate dev",
    "db:deploy": "pnpm --filter @pg/db prisma migrate deploy",
    "db:studio": "pnpm --filter @pg/db prisma studio",
    "db:seed": "pnpm --filter @pg/db db:seed",
    "audit": "pnpm audit --audit-level=high",
    "audit:fix": "pnpm audit --fix",
    "security:scan": "pnpm audit --audit-level=moderate && echo 'Run: trivy fs . && gitleaks detect'",
    "docker:up": "docker compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f docker/docker-compose.yml down",
    "docker:logs": "docker compose -f docker/docker-compose.yml logs -f",
    "docker:build": "docker compose -f docker/docker-compose.yml build"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "eslint": "9.15.0",
    "prettier": "3.3.3",
    "turbo": "2.3.0",
    "typescript": "5.6.3"
  }
}
