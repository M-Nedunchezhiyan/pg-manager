# Copy to .env and fill. Never commit .env.
# All secrets here are placeholders — generate real values with `openssl rand -base64 48`.

# ─── Node ─────────────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── Database (Postgres) ──────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=apple@123
POSTGRES_DB=pgmanager
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:apple%40123@postgres:5432/pgmanager?schema=public&sslmode=prefer
# Note: @ in the URL must be URL-encoded as %40.

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password
REDIS_URL=redis://:change_me_redis_password@redis:6379

# ─── File storage (local disk) ────────────────────────────────────────────────
# Absolute path where uploaded files (photos, ID images) are written.
# Files are NEVER served as raw static — fetched via /api/v1/files/:key with auth.
STORAGE_ROOT=./.data/uploads

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 48
JWT_ACCESS_SECRET=change_me_min_48_chars_random_string
JWT_REFRESH_SECRET=change_me_different_48_chars_random_string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
NEXTAUTH_SECRET=change_me_nextauth_48_chars_random
NEXTAUTH_URL=http://localhost:3000

# ─── API ──────────────────────────────────────────────────────────────────────
API_PORT=4000
API_URL=http://localhost:4000
WEB_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# ─── Encryption for PII at rest (AES-256-GCM) ────────────────────────────────
# Generate: openssl rand -hex 32   (must be exactly 64 hex chars)
PII_ENCRYPTION_KEY=change_me_64_hex_chars_exactly_for_aes_256_gcm_encryption_key_xx

# ─── Shared cipher (server + browser) ─────────────────────────────────────────
# Used to wrap JWT cookies and opaque ID payloads so values aren't visible as
# raw text in DevTools / Postman. AES-256-GCM, 64 hex chars (32 bytes).
# Generate: openssl rand -hex 32
# IMPORTANT: this key is shipped to the browser. It deters casual inspection,
# but is recoverable from the JS bundle — it is NOT a secrecy guarantee. Real
# protection still comes from HTTPS + httpOnly cookies + auth.
SHARED_CIPHER_KEY=change_me_64_hex_chars_for_shared_aes_256_gcm_cipher_xxxxxxxxx
NEXT_PUBLIC_SHARED_CIPHER_KEY=change_me_64_hex_chars_for_shared_aes_256_gcm_cipher_xxxxxxxxx

# ─── Rate limiting ────────────────────────────────────────────────────────────
THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT=100
AUTH_THROTTLE_LIMIT=5

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ─── Seed (initial owner login) ───────────────────────────────────────────────
SEED_OWNER_EMAIL=postgres@pg.local
SEED_OWNER_PASSWORD=apple@123
